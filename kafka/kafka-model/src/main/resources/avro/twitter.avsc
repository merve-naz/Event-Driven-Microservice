{
  "namespace": "com.microservices.demo.kafka.avro.model",
  "type": "record",
  "name": "TwitterAvroModel",
  "fields": [
    {
      "name": "userId",
      "type": "long"
    },
    {
      "name": "id",
      "type": "long"
    },
    {
      "name": "text",
      "type": ["null", "string"],
      "default": null
    },
    {
      "name": "createdAt",
      "type": ["null", "long"],
      "logicalType": "timestamp-millis",
      "default": null
    }
  ]
}